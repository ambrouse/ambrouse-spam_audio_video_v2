# Copy this file to .env for local runtime overrides.
# Keep GPU as the default path. Do not set these to cpu on the production machine.
SETUP_TTS_DEVICE=cuda
SPAM_TTS_DEVICE=cuda

# Web app port. setup.sh can still auto-pick another port if this one is busy.
PORT=8080

# Browser bridge controller.
BRIDGE_BASE_URL=http://127.0.0.1:8008
BRIDGE_PORTS=9222,9223,9224

# Video runtime. Encoder selection is GPU-only in the pipeline:
# auto -> h264_nvenc, h264_qsv, or h264_amf; CPU/libx264 is blocked.
VIDEO_ENCODER=auto
VIDEO_RENDER_WORKERS=4
VIDEO_BRIDGE_BATCH_SIZE=24
VIDEO_GEMINI_PROMPT_STRICT=0
VIDEO_ALLOW_PLACEHOLDER=0

# Optional stable-diffusion.cpp overrides.
# VIDEO_SD_EXECUTABLE=
# VIDEO_SD_MODEL_PATH=

# Optional Chrome override for crawl/open-browser helpers.
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
