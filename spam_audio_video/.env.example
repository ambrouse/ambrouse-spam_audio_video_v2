# Copy this file to .env for local runtime overrides.
# Keep GPU as the default path. Do not set these to cpu on the production machine.
SETUP_TTS_DEVICE=cuda
SPAM_TTS_DEVICE=cuda
# Faster default for VoxCPM diffusion sampling. Raise to 8 if a voice needs
# maximum stability, lower only after listening tests.
SPAM_TTS_INFERENCE_TIMESTEPS=6
# Aggressive VoxCPM speed profile. Retry stays on because VoxCPM can crash
# internally when it is fully disabled; max retry is reduced from 3 to 1.
SPAM_TTS_RETRY_BADCASE=1
SPAM_TTS_RETRY_BADCASE_MAX_TIMES=1
SPAM_TTS_CFG_VALUE=2.0
SPAM_TTS_MAX_LEN_SCALE=2.9
SPAM_TTS_MAX_LEN_PADDING=70

# Web app port. setup.sh can still auto-pick another port if this one is busy.
PORT=8080

# Browser bridge controller.
BRIDGE_BASE_URL=http://127.0.0.1:8008
BRIDGE_PORTS=9222,9223,9224

# Video runtime. Encoder selection is GPU-only in the pipeline:
# auto -> h264_nvenc, h264_qsv, or h264_amf; CPU/libx264 is blocked.
# Production video uses the Rust/D3D11/NVENC full-timeline renderer only.
# FFmpeg is used only for final container/audio mux. There is no segmented
# clip-render fallback in the main pipeline.
VIDEO_ENCODER=auto
VIDEO_PRESET=throughput
VIDEO_RENDER_WORKERS=6
# Optional override for story_gpu_renderer.exe.
# SPAM_VIDEO_RENDERER_BIN=
VIDEO_BRIDGE_BATCH_SIZE=24
VIDEO_GEMINI_PROMPT_STRICT=0
VIDEO_ALLOW_PLACEHOLDER=0

# Optional stable-diffusion.cpp overrides.
# VIDEO_SD_EXECUTABLE=
# VIDEO_SD_MODEL_PATH=

# Optional Chrome override for crawl/open-browser helpers.
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
